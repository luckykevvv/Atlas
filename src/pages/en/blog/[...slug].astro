---
import { getCollection, render } from 'astro:content';
import MarkdownLayout from '../../../layouts/MarkdownLayout.astro';
import { cleanContentSlug } from '../../../config/i18n';
import { getBacklinks } from '../../../utils/knowledge';
import { getEntryDescription, getEntryTitle } from '../../../utils/content';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

	return posts.map((post) => ({
		params: { slug: cleanContentSlug(post.id) },
		props: { post },
	}));
}

const { post } = Astro.props;
const allPosts = await getCollection('blog');
const backlinks = getBacklinks(post.id, allPosts);
const { Content } = await render(post);
---

<MarkdownLayout title={getEntryTitle(post)} description={getEntryDescription(post)} date={post.data.pubDate} tags={post.data.tags} backlinks={backlinks}>
	<Content />
</MarkdownLayout>
